# --- Sunucu ---
PORT=4000
# upload.html ve QR linklerinin işaret edeceği herkese açık temel URL
PUBLIC_BASE_URL=http://localhost:4000

# --- PostgreSQL ---
DATABASE_URL=postgresql://user:pass@localhost:5432/media_tv?schema=public

# --- Kendi JWT'miz (TV oturumu) ---
# openssl rand -hex 32 ile üret
JWT_SECRET=change-me-please-32-bytes-min

# Google refresh_token'larını DB'de şifrelemek için 32-byte hex anahtar
# openssl rand -hex 32
ENCRYPTION_KEY=change-me-64-hex-chars

# --- Google OAuth (TV / Limited-Input client) ---
# Google Cloud Console > Credentials > OAuth client ID > "TVs and Limited Input devices"
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxx

# --- Cloudflare R2 (S3 uyumlu) ---
R2_ACCOUNT_ID=xxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxx
R2_BUCKET=media-tv-displayer
# https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://xxxxxxxx.r2.cloudflarestorage.com
