generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaStatus {
  PENDING // R2'ye kopyalama/işleme bekliyor
  READY // oynatılabilir
  FAILED
}

enum DeviceStatus {
  UNPAIRED // TV kod gösteriyor, henüz panelden bağlanmadı
  PAIRED // klinik + galeri atanmış, oynatabilir
}

enum GalleryKind {
  DEVICE // tek bir cihaza özel galeri
  SHARED // klinik genelinde ortak galeri
}

// Panele login olan yönetici. Çoklu admin; hepsi tüm klinikleri yönetir.
model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}

// Yöneticinin elle eklediği klinik. Cihazlar ve galeriler kliniğe bağlıdır.
model Clinic {
  id        String   @id @default(cuid())
  name      String
  address   String?
  createdAt DateTime @default(now())

  devices    Device[]
  galleries  Gallery[]
  mediaItems MediaItem[]

  @@index([name])
}

// Fiziksel TV/ekran. Açılışta UNPAIRED kod gösterir; panelden bağlanınca PAIRED olur.
model Device {
  id     String       @id @default(cuid())
  name   String?
  status DeviceStatus @default(UNPAIRED)

  clinicId String?
  clinic   Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  // Eşleştirme: TV ekranda pairingCode gösterir, poll için pairingSecret'i saklar.
  // Bağlanınca ikisi de temizlenir.
  pairingCode   String? @unique
  pairingSecret String?

  // Atanan galeriler. ownGallery cihaza özeldir (bağlanınca otomatik oluşturulur),
  // sharedGallery kliniğin ortak galerisidir (opsiyonel).
  ownGalleryId String?  @unique
  ownGallery   Gallery? @relation("DeviceOwnGallery", fields: [ownGalleryId], references: [id], onDelete: SetNull)

  sharedGalleryId String?
  sharedGallery   Gallery? @relation("DeviceSharedGallery", fields: [sharedGalleryId], references: [id], onDelete: SetNull)

  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([clinicId])
  @@index([pairingCode])
}

// Sıralı medya koleksiyonu (eski Playlist'in yerine). Oynatma ayarlarını taşır.
model Gallery {
  id       String      @id @default(cuid())
  clinicId String
  clinic   Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  kind     GalleryKind
  name     String

  // Oynatma (loop) ayarları
  loop             Boolean @default(true)
  shuffle          Boolean @default(false)
  imageDurationSec Int     @default(8)

  createdAt DateTime @default(now())

  items GalleryItem[]

  // ters ilişkiler (Device tarafındaki atamalar)
  ownerDevice   Device?  @relation("DeviceOwnGallery")
  sharedDevices Device[] @relation("DeviceSharedGallery")

  @@index([clinicId, kind])
}

model GalleryItem {
  id          String    @id @default(cuid())
  galleryId   String
  gallery     Gallery   @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  mediaItemId String
  mediaItem   MediaItem @relation("ItemMedia", fields: [mediaItemId], references: [id], onDelete: Cascade)
  position    Int
  // görseller için ekranda kalma süresi (sn). Video ise yok sayılır (tam uzunluk oynar).
  durationSec Int       @default(8)

  // --- Overlay (bindirme): içeriğin üstünde gösterilir ---
  // Altta sağdan sola kayan yazı (boşsa gösterilmez).
  tickerText     String?
  tickerColor    String?    @default("#ffffff") // kayan yazı metin rengi (hex)
  tickerOpacity  Float?     @default(1)         // kayan yazı opaklığı (0..1)
  tickerBgColor  String?    @default("#000000") // kayan yazı şeridi arka plan rengi (hex)
  tickerBgOpacity Float?    @default(0.6)       // kayan yazı şeridi opaklığı (0..1)
  // Reklam görseli (havuzdan bir IMAGE) — videoyu kapatmaz, bir kenara yerleşir ve
  // içeriği o kadar küçültür ("squeeze-back"). side: hangi kenar; size: o kenarın
  // kapladığı ekran oranı (0..1).
  overlayImageId String?
  overlayImage   MediaItem? @relation("ItemOverlay", fields: [overlayImageId], references: [id], onDelete: SetNull)
  overlaySide    String?    @default("right") // left | right | top | bottom
  overlaySize    Float?     @default(0.25)     // şerit kalınlığı (ekran oranı, 0..1)

  @@unique([galleryId, mediaItemId])
  @@index([galleryId, position])
}

// Panelden R2'ye yüklenen medya. Klinik havuzuna aittir; galerilere eklenir.
model MediaItem {
  id           String      @id @default(cuid())
  clinicId     String
  clinic       Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  type         MediaType
  status       MediaStatus @default(PENDING)
  r2Key        String? // R2 nesne anahtarı (READY olunca dolu)
  thumbKey     String? // video önizleme karesi (R2 anahtarı); görsellerde boş
  originalName String?
  mimeType     String?
  sizeBytes    Int?
  durationSec  Float? // video uzunluğu (sn)
  width        Int?
  height       Int?
  // içerik hash'i — aynı dosyanın klinik içinde tekrar yüklenmesini önler
  contentHash  String?
  createdAt    DateTime    @default(now())

  galleryItems    GalleryItem[] @relation("ItemMedia")
  overlayForItems GalleryItem[] @relation("ItemOverlay")

  @@unique([clinicId, contentHash])
  @@index([clinicId, status])
  @@index([clinicId, createdAt])
}
